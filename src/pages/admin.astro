// ── TAB SWITCHING ─────────────────────────────────────
function showTab(id) {
  document.querySelectorAll('.admin-tab').forEach(t => t.style.display = 'none');
  document.getElementById('tab-' + id).style.display = 'block';
  document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
  event.target.classList.add('active');
  if (id === 'products') renderProductsTable();
}

// ── PRODUCTS TABLE ────────────────────────────────────
function renderProductsTable() {
  const tbody = document.getElementById('productsTableBody');
  tbody.innerHTML = PRODUCTS.map(p => `
    <tr>
      <td><div style="width:44px;height:56px;border-radius:4px;overflow:hidden;background:var(--surface);"><img src="${p.img}" alt="" style="width:100%;height:100%;object-fit:cover;object-position:top;"></div></td>
      <td style="font-size:13px;font-weight:500;">${p.name}</td>
      <td style="font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.1em;">${p.cat}</td>
      <td style="font-family:'DM Mono',monospace;">₦${p.price.toLocaleString()}</td>
      <td style="font-family:'DM Mono',monospace;">$${Math.round(p.price/1550)}</td>
      <td><span style="font-size:10px;font-weight:600;color:${p.stock ? 'var(--green-cta)' : '#C0392B'};">${p.stock ? 'In Stock' : 'Out'}</span></td>
      <td><button style="font-size:10px;padding:5px 12px;border:1px solid var(--border-strong);border-radius:3px;background:white;cursor:pointer;">Edit</button></td>
    </tr>
  `).join('');
}

// ── MARK SHIPPED ──────────────────────────────────────
function markShipped(btn) {
  const row = btn.closest('tr');
  const pill = row.querySelector('.status-pill');
  pill.className = 'status-pill pill-shipped';
  pill.textContent = '● Shipped';
  btn.textContent = '✓ Done';
  btn.disabled = true;
  btn.style.opacity = '0.5';
  showToast('✓ Order marked as shipped');
}

// ── PUBLISH PRODUCT ───────────────────────────────────
function publishProduct() {
  const name = document.getElementById('prodName').value;
  if (!name) { showToast('Please enter a product name'); return; }
  showToast('✓ Product published to your store!');
  document.getElementById('prodName').value = '';
  document.getElementById('prodDesc').value = '';
  document.getElementById('priceRetail').value = '';
  document.getElementById('priceWholesale').value = '';
  document.getElementById('priceUSD').value = '';
}

// ── CALC USD ──────────────────────────────────────────
function calcUSD() {
  const ngn = parseInt(document.getElementById('priceRetail').value) || 0;
  document.getElementById('priceUSD').value = Math.round(ngn / 1550);
}

// ── SAVE RATES ────────────────────────────────────────
function saveRates() {
  showToast('✓ Rates saved — all product prices updated sitewide');
}

// ── UPLOAD ZONE ───────────────────────────────────────
document.getElementById('uploadZone').addEventListener('click', () => {
  document.getElementById('fileInput').click();
});

// ── TOAST ─────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}
</script>

</body>
</html>
