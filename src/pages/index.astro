// ── CURRENCY ──────────────────────────────────────────
function fmt(ngn, cur = currency) {
  const v = ngn * RATES[cur];
  return SYMS[cur] + Math.round(v).toLocaleString();
}

function setCurrency(c) {
  currency = c;
  // Update nav select style on scroll
  const sel = document.getElementById('currencySelect');
  renderFeaturedDresses();
  renderHomeFabrics();
  renderHomeAccessories();
  updateCartDisplay();
  updatePreviewPrices();
}

function updatePreviewPrices() {
  const p1 = document.getElementById('prev-price-1');
  const p2 = document.getElementById('prev-price-2');
  const p3 = document.getElementById('prev-price-3');
  if (p1) p1.textContent = fmt(35000);
  if (p2) p2.textContent = fmt(28000);
  if (p3) p3.textContent = fmt(25000);
}

// ── HERO SLIDESHOW ────────────────────────────────────
let slideIndex = 0;
const SLIDE_COUNT = 12;
let slideInterval;

function goSlide(n) {
  document.getElementById('slide-' + slideIndex).classList.remove('active');
  document.querySelectorAll('.hero-dot')[slideIndex].classList.remove('active');
  slideIndex = n;
  document.getElementById('slide-' + slideIndex).classList.add('active');
  document.querySelectorAll('.hero-dot')[slideIndex].classList.add('active');
}

function nextSlide() {
  goSlide((slideIndex + 1) % SLIDE_COUNT);
}

function startSlideshow() {
  slideInterval = setInterval(nextSlide, 5500);
}

// ── NAV SCROLL ────────────────────────────────────────
window.addEventListener('scroll', () => {
  const nav = document.getElementById('mainNav');
  const sel = document.getElementById('currencySelect');
  const adminBtn = document.getElementById('adminBtn');
  if (window.scrollY > 80) {
    nav.classList.remove('transparent');
    nav.classList.add('scrolled');
    sel.style.borderColor = 'var(--border-strong)';
    sel.style.background = 'white';
    sel.style.color = 'var(--ink)';
    adminBtn.style.borderColor = 'var(--ink)';
    adminBtn.style.color = 'var(--ink)';
  } else {
    nav.classList.add('transparent');
    nav.classList.remove('scrolled');
    sel.style.borderColor = 'rgba(255,255,255,0.25)';
    sel.style.background = 'rgba(255,255,255,0.08)';
    sel.style.color = 'white';
    adminBtn.style.borderColor = 'rgba(255,255,255,0.35)';
    adminBtn.style.color = 'rgba(255,255,255,0.8)';
  }
});

// ── WISHLIST ──────────────────────────────────────────
function toggleFav(id) {
  const idx = wishlist.indexOf(id);
  if (idx > -1) { wishlist.splice(idx, 1); showToast('Removed from wishlist'); }
  else { wishlist.push(id); showToast('♥ Added to wishlist'); }
  localStorage.setItem('afroposh_wish', JSON.stringify(wishlist));
  updateWishCount();
  renderFeaturedDresses(); renderHomeFabrics(); renderHomeAccessories();
}
function updateWishCount() {
  const el = document.getElementById('wishCount');
  if (wishlist.length > 0) { el.style.display = 'flex'; el.textContent = wishlist.length; }
  else { el.style.display = 'none'; }
}
function toggleWishlistPanel() { showToast('Wishlist: ' + wishlist.length + ' items saved'); }

// ── AUTH CHECK ────────────────────────────────────────
function checkAuth() {
  const user = JSON.parse(localStorage.getItem('afroposh_user') || 'null');
  const btn = document.getElementById('adminBtn');
  if (user) {
    btn.textContent = user.role === 'admin' ? '📊 Dashboard' : '👤 ' + user.firstName;
    btn.href = user.role === 'admin' ? '/admin' : '#';
    if (user.role !== 'admin') btn.onclick = function(e) { e.preventDefault(); if(confirm('Log out?')) { localStorage.removeItem('afroposh_user'); location.reload(); } };
  }
}

// ── PRODUCT CARD BUILDERS ─────────────────────────────
function buildProductCard(p) {
