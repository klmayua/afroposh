---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Afroposh Afriture — Premium African Fashion | Lagos · Accra · Yaoundé</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="description" content="Premium Ankara Bubu Dresses, Batik Fabrics, and Artisan Accessories. Pan-African fashion delivered worldwide.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

<!-- PREMIUM TICKER -->
<div class="premium-ticker" id="premiumTicker">
  <div class="ticker-track">
    <span class="ticker-item ticker-gold">✦ Premium Batik Fabrics Now In Stock</span>
    <span class="ticker-item ticker-green">🚚 Free Delivery on Orders Over ₦100,000</span>
    <span class="ticker-item ticker-blue">📦 Wholesale Available — Minimum 6 Yards</span>
    <span class="ticker-item ticker-purple">🔥 New Bubu Dress Collection Just Dropped</span>
    <span class="ticker-item ticker-gold">✦ Premium Batik Fabrics Now In Stock</span>
    <span class="ticker-item ticker-green">🚚 Free Delivery on Orders Over ₦100,000</span>
    <span class="ticker-item ticker-blue">📦 Wholesale Available — Minimum 6 Yards</span>
    <span class="ticker-item ticker-purple">🔥 New Bubu Dress Collection Just Dropped</span>
  </div>
</div>

<!-- NAV -->
<nav class="main-nav transparent" id="mainNav">
  <div class="nav-inner">
    <ul class="nav-links">
      <li><a href="/shop?cat=bubus">Bubu Dresses</a></li>
      <li><a href="/shop?cat=fabrics">Fabrics</a></li>
      <li><a href="/shop?cat=accessories">Accessories</a></li>
      <li><a href="/wholesale">Wholesale</a></li>
    </ul>
    <a href="/" class="nav-logo">Afroposh <span>Afriture</span></a>
    <div class="nav-ctas">
      <select id="currencySelect" onchange="setCurrency(this.value)"
        style="font-family:'DM Mono',monospace;font-size:11px;border:1px solid rgba(255,255,255,0.25);border-radius:3px;padding:6px 10px;background:rgba(255,255,255,0.08);color:white;cursor:pointer;letter-spacing:0.05em;transition:all 0.3s;">
        <option value="NGN">₦ NGN</option>
        <option value="USD">$ USD</option>
        <option value="GBP">£ GBP</option>
        <option value="FCFA">FCFA</option>
        <option value="GHS">GHS</option>
      </select>
      <button onclick="toggleWishlistPanel()" title="Wishlist" style="position:relative;width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:white;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.3s;">
        ♥
        <span id="wishCount" style="position:absolute;top:-2px;right:-2px;width:18px;height:18px;background:#C0392B;border-radius:50%;font-size:10px;font-weight:700;color:white;display:none;align-items:center;justify-content:center;font-family:'DM Mono',monospace;">0</span>
      </button>
      <button onclick="toggleCart()" title="Cart" style="position:relative;width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:white;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.3s;">
        🛒
        <span id="cartCount" style="position:absolute;top:-2px;right:-2px;width:18px;height:18px;background:var(--gold);border-radius:50%;font-size:10px;font-weight:700;color:white;display:flex;align-items:center;justify-content:center;font-family:'DM Mono',monospace;">0</span>
      </button>
      <a href="/login" id="adminBtn" style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:8px 16px;border:1.5px solid rgba(255,255,255,0.35);border-radius:3px;color:rgba(255,255,255,0.8);transition:all 0.3s;text-decoration:none;">Login</a>
    </div>
  </div>
</nav>

<!-- MOBILE BOTTOM NAV -->
<div class="mobile-bottom-nav" id="mobileBottomNav">
  <div class="mob-nav-inner">
    <a href="/" class="mob-nav-item active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>Home</span>
    </a>
    <a href="/shop" class="mob-nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <span>Shop</span>
    </a>
    <button class="mob-nav-item" onclick="toggleCart()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <span>Cart</span>
      <span class="mob-nav-badge" id="mobCartCount" style="display:none;">0</span>
    </button>
    <button class="mob-nav-item" onclick="toggleWishlistPanel()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <span>Wishlist</span>
    </button>
    <button class="mob-nav-item" id="mobMoreBtn" onclick="toggleMobileMore()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
      <span>More</span>
    </button>
  </div>
</div>

<!-- MOBILE MORE BACKDROP -->
<div class="mobile-more-backdrop" id="moreBackdrop" onclick="toggleMobileMore()"></div>

<!-- MOBILE MORE MENU (polished slide-up) -->
<div class="mobile-more-overlay" id="mobileMoreMenu">
  <div style="width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 12px;"></div>
  <p style="font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;color:var(--ink);text-align:center;margin:0 0 16px;">Quick Actions</p>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
    <a href="/wholesale" style="padding:18px 12px;background:var(--surface);border-radius:12px;text-decoration:none;color:var(--ink);font-size:11px;font-weight:600;text-align:center;display:flex;flex-direction:column;align-items:center;gap:8px;letter-spacing:0.02em;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
      Wholesale
    </a>
    <a href="https://wa.me/2371184837" target="_blank" style="padding:18px 12px;background:#25D366;border-radius:12px;text-decoration:none;color:white;font-size:11px;font-weight:600;text-align:center;display:flex;flex-direction:column;align-items:center;gap:8px;letter-spacing:0.02em;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
      Chat With Us
    </a>
    <a href="/login" id="mobLoginBtn" style="padding:18px 12px;background:var(--ink);border-radius:12px;text-decoration:none;color:white;font-size:11px;font-weight:600;text-align:center;display:flex;flex-direction:column;align-items:center;gap:8px;letter-spacing:0.02em;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Login / Account
    </a>
    <div style="padding:18px 12px;background:var(--surface);border-radius:12px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:8px;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      <select id="mobCurrencySelect" onchange="setCurrency(this.value)" style="font-family:'DM Mono',monospace;font-size:11px;border:1px solid var(--border);border-radius:4px;padding:6px 8px;background:white;color:var(--ink);cursor:pointer;width:100%;font-weight:500;">
        <option value="NGN">₦ NGN</option>
        <option value="USD">$ USD</option>
        <option value="GBP">£ GBP</option>
        <option value="FCFA">FCFA</option>
        <option value="GHS">GHS</option>
      </select>
    </div>
  </div>
</div>

<!-- WHATSAPP CHAT FAB (Desktop only) -->
<a href="https://wa.me/2371184837" target="_blank" class="chat-fab-desktop" title="Chat with us on WhatsApp" aria-label="Chat on WhatsApp">
  <svg viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
</a>

<!-- BACK TO TOP -->
<button class="back-to-top" id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Back to top" aria-label="Back to top">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
</button>

<!-- COOKIE CONSENT -->
<div class="cookie-banner" id="cookieBanner">
  <p>We use cookies to enhance your shopping experience and analyse site traffic. By clicking "Accept", you agree to our use of cookies.</p>
  <button class="cookie-btn-accept" onclick="acceptCookies()">Accept</button>
  <button class="cookie-btn-decline" onclick="declineCookies()">Decline</button>
</div>

<!-- ============================================
     CINEMATIC HERO
     - Auto-rotating slideshow of real product images
     - Ken Burns zoom on each slide
     - Animated typography entrance
     - Floating product preview cards
     - Gold accent line
============================================ -->
<section class="hero-section" id="hero">

  <!-- SLIDES — Bubu→Ankara→Accessory cycle ×4 -->
  <div class="hero-slide active" id="slide-0">
    <img src="/images/dresses/afroposh_bubu7.jpg" alt="Green Kente Short Bubu" loading="eager">
  </div>
  <div class="hero-slide" id="slide-1">
    <img src="/images/fabrics/afroposh_ankara1.jpg" alt="Ocean Wave Batik Fabric" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-2">
    <img src="/images/accessories/afroposh_combo_set.jpg" alt="Beaded Jewellery Set + Clutch" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-3">
    <img src="/images/dresses/afroposh_bubu12.jpg" alt="Burgundy Navy Stripe Bubu" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-4">
    <img src="/images/fabrics/afroposh_ankara3.jpg" alt="Spiral Adinkra Batik Fabric" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-5">
    <img src="/images/accessories/afroposh_hat_and_bag.jpg" alt="Ankara Tote Bags & Hat" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-6">
    <img src="/images/dresses/afroposh_bubu4.jpg" alt="Olive Gold Stripe Maxi" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-7">
    <img src="/images/fabrics/afroposh_ankara6.jpg" alt="Harvest Splatter Batik" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-8">
    <img src="/images/accessories/afroposh_necklace.jpg" alt="Zulu Beaded Collar Necklace" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-9">
    <img src="/images/dresses/afroposh_bubu01.jpg" alt="Tribal Geometric Maxi Bubu" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-10">
    <img src="/images/fabrics/afroposh_ankara.jpg" alt="Galaxy Night Batik" loading="lazy">
  </div>
  <div class="hero-slide" id="slide-11">
    <img src="/images/accessories/afroposh_wristwatch.jpg" alt="Beaded Watch Cuff" loading="lazy">
  </div>

  <!-- Gradient + texture overlays -->
  <div class="hero-overlay-gradient"></div>
  <div class="hero-texture"></div>

  <!-- Gold accent line at bottom -->
  <div class="hero-accent-line" id="heroAccentLine"></div>

  <!-- Main content -->
  <div class="hero-content">
    <p class="hero-eyebrow">Afroposh Afriture — Premium African Fashion</p>
    <h1 class="hero-title">
      <span class="outline-text">Dressed</span>
      <em>in Heritage</em>
    </h1>
    <p class="hero-sub">Handcrafted Bubu dresses, premium Ankara fabrics, and artisan accessories. From our ateliers to your wardrobe — wherever you are in the world.</p>
    <div class="hero-cities">
      <span class="hero-city-tag">Lagos</span>
      <span class="hero-city-tag">Accra</span>
      <span class="hero-city-tag">Yaoundé</span>
      <span class="hero-city-tag">Diaspora</span>
    </div>
    <div class="hero-ctas">
      <a href="/shop" class="btn-primary">Shop Collection →</a>
      <a href="/wholesale" class="btn-outline-white">Wholesale Enquiry ↗</a>
    </div>
  </div>

  <!-- Floating product preview cards (right side) -->
  <div class="hero-preview-cards" id="heroPreviewCards">
    <div class="hero-preview-card" onclick="openModal(2)">
      <img src="/images/dresses/afroposh_bubu01.jpg" alt="">
      <div class="hero-preview-card-label">
        Tribal Maxi<br>
        <span class="hero-preview-price" id="prev-price-1">₦35,000</span>
      </div>
    </div>
    <div class="hero-preview-card" onclick="openModal(23)">
      <img src="/images/accessories/afroposh_necklace.jpg" alt="">
      <div class="hero-preview-card-label">
        Zulu Collar<br>
        <span class="hero-preview-price" id="prev-price-2">₦28,000</span>
      </div>
    </div>
    <div class="hero-preview-card" onclick="openModal(16)">
      <img src="/images/fabrics/afroposh_ankara3.jpg" alt="">
      <div class="hero-preview-card-label">
        Spiral Adinkra<br>
        <span class="hero-preview-price" id="prev-price-3">₦25,000</span>
      </div>
    </div>
  </div>

  <!-- Slide dots -->
  <div class="hero-counter" id="heroCounter">
    <div class="hero-dot active" onclick="goSlide(0)"></div>
    <div class="hero-dot" onclick="goSlide(1)"></div>
    <div class="hero-dot" onclick="goSlide(2)"></div>
    <div class="hero-dot" onclick="goSlide(3)"></div>
    <div class="hero-dot" onclick="goSlide(4)"></div>
    <div class="hero-dot" onclick="goSlide(5)"></div>
    <div class="hero-dot" onclick="goSlide(6)"></div>
    <div class="hero-dot" onclick="goSlide(7)"></div>
    <div class="hero-dot" onclick="goSlide(8)"></div>
    <div class="hero-dot" onclick="goSlide(9)"></div>
    <div class="hero-dot" onclick="goSlide(10)"></div>
    <div class="hero-dot" onclick="goSlide(11)"></div>
  </div>

  <!-- Scroll cue -->
  <div class="hero-scroll-cue">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-inner">
    <div class="trust-item">
      <div class="trust-icon-wrap">🚚</div>
      <div class="trust-text">
        <strong>Worldwide Delivery</strong>
        <span>24–72hrs domestic · 5–10 days international</span>
      </div>
    </div>
    <div class="trust-item">
      <div class="trust-icon-wrap">💳</div>
      <div class="trust-text">
        <strong>Secure Payments</strong>
        <span>Flutterwave · Paystack · Bank Transfer</span>
      </div>
    </div>
    <div class="trust-item">
      <div class="trust-icon-wrap">💬</div>
      <div class="trust-text">
        <strong>WhatsApp Support</strong>
        <span>Direct ordering & custom requests</span>
      </div>
    </div>
    <div class="trust-item">
      <div class="trust-icon-wrap">📦</div>
      <div class="trust-text">
        <strong>Wholesale Available</strong>
        <span>Minimum order from 6 yards</span>
      </div>
    </div>
    <div class="trust-item">
      <div class="trust-icon-wrap">✦</div>
      <div class="trust-text">
        <strong>Pan-African</strong>
        <span>Lagos · Accra · Yaoundé</span>
      </div>
    </div>
  </div>
</div>

<!-- CATEGORIES -->
<section class="sp" style="max-width:1400px;margin:0 auto;padding:80px 32px;">
  <div style="margin-bottom:48px;">
    <p class="section-eyebrow">Shop by Collection</p>
    <h2 class="section-title">Find Your <em>Perfect Piece</em></h2>
  </div>
  <div class="cat-grid">
    <a href="/shop?cat=bubus" class="cat-card">
      <img src="/images/dresses/afroposh_bubu2.jpg" alt="Bubu Dresses">
      <div class="cat-overlay">
        <span class="cat-label">Ready to Wear</span>
        <h3 class="cat-name">Bubu<br>Dresses</h3>
        <p class="cat-count">12 styles available</p>
        <span class="cat-arrow">Shop Now →</span>
      </div>
    </a>
    <a href="/shop?cat=fabrics" class="cat-card">
      <img src="/images/fabrics/afroposh_ankara3.jpg" alt="Fabrics">
      <div class="cat-overlay">
        <span class="cat-label">Wholesale & Retail</span>
        <h3 class="cat-name">Ankara<br>Fabrics</h3>
        <p class="cat-count">9 prints · 6-yard bales</p>
        <span class="cat-arrow">Shop Now →</span>
      </div>
    </a>
    <a href="/shop?cat=accessories" class="cat-card">
      <img src="/images/accessories/afroposh_combo_set.jpg" alt="Accessories">
      <div class="cat-overlay">
        <span class="cat-label">Artisan Made</span>
        <h3 class="cat-name">Beads &<br>Accessories</h3>
        <p class="cat-count">6 collections</p>
        <span class="cat-arrow">Shop Now →</span>
      </div>
    </a>
  </div>
</section>

<!-- WAVE DIVIDER: white → surface -->
<div class="wave-divider" style="background:var(--surface);">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" style="display:block;width:100%;height:80px;"><path d="M0,0 C360,80 1080,0 1440,60 L1440,0 L0,0 Z" fill="white"/></svg>
</div>

<!-- FEATURED DRESSES -->
<section class="sp" style="background:var(--surface);padding:0 32px 80px;">
  <div style="max-width:1400px;margin:0 auto;">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;flex-wrap:wrap;gap:16px;">
      <div>
        <p class="section-eyebrow">New Arrivals</p>
        <h2 class="section-title">Featured <em>Bubu Dresses</em></h2>
      </div>
      <a href="/shop?cat=bubus" style="font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);text-decoration:none;display:flex;align-items:center;gap:6px;">View All Dresses →</a>
    </div>
    <div class="product-grid" id="featured-dresses"></div>
  </div>
</section>

<!-- WAVE DIVIDER: surface → white -->
<div class="wave-divider" style="background:white;">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" style="display:block;width:100%;height:80px;"><path d="M0,0 C480,80 960,0 1440,50 L1440,0 L0,0 Z" fill="var(--surface)"/></svg>
</div>

<!-- FABRIC SECTION -->
<section class="sp" style="max-width:1400px;margin:0 auto;padding:40px 32px 80px;">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;flex-wrap:wrap;gap:16px;">
    <div>
      <p class="section-eyebrow">Premium Fabrics</p>
      <h2 class="section-title">Ankara & <em>Batik Fabrics</em></h2>
