  { id:27, name:'Full Beaded Set + Clutch',        cat:'accessories', catLabel:'Jewellery Set', img:'/images/accessories/afroposh_combo_set.jpg',     price:55000, badge:'new',  desc:'Complete set: choker, long necklace, cuff bracelet, and leather clutch.' },
];

let activeFilter = 'all';
let activeSort = 'featured';

// ── CURRENCY ──────────────────────────────────────────
function fmt(ngn, cur = currency) {
  const v = ngn * RATES[cur];
  return SYMS[cur] + Math.round(v).toLocaleString();
}
function setCurrency(c) { currency = c; renderGrid(); updateCartDisplay(); }

// ── AUTH CHECK ────────────────────────────────────────
function checkAuth() {
  const user = JSON.parse(localStorage.getItem('afroposh_user') || 'null');
  const btn = document.getElementById('navAuthBtn');
  if (user) {
    btn.textContent = user.role === 'admin' ? '📊 Dashboard' : '👤 ' + user.firstName;
    btn.href = user.role === 'admin' ? '/admin' : '#';
    if (user.role !== 'admin') btn.onclick = function(e) { e.preventDefault(); if(confirm('Log out?')) { localStorage.removeItem('afroposh_user'); location.reload(); } };
  }
}

// ── FILTER & SORT ─────────────────────────────────────
function filterBy(cat) {
  activeFilter = cat;
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  renderGrid();
}
function sortProducts(val) { activeSort = val; renderGrid(); }

function getFilteredProducts() {
  let filtered = activeFilter === 'all' ? [...PRODUCTS] : PRODUCTS.filter(p => p.cat === activeFilter);
  switch(activeSort) {
    case 'price-asc': filtered.sort((a,b) => a.price - b.price); break;
    case 'price-desc': filtered.sort((a,b) => b.price - a.price); break;
    case 'newest': filtered.sort((a,b) => b.id - a.id); break;
    default: break;
  }
  return filtered;
}

// ── WISHLIST ──────────────────────────────────────────
function toggleFav(id) {
  const idx = wishlist.indexOf(id);
  if (idx > -1) { wishlist.splice(idx, 1); showToast('Removed from wishlist'); }
  else { wishlist.push(id); showToast('♥ Added to wishlist'); }
  localStorage.setItem('afroposh_wish', JSON.stringify(wishlist));
  updateWishCount();
  renderGrid();
}
function updateWishCount() {
  const el = document.getElementById('wishCount');
  if (wishlist.length > 0) { el.style.display = 'flex'; el.textContent = wishlist.length; }
  else { el.style.display = 'none'; }
}
function toggleWishlistPanel() { showToast('Wishlist: ' + wishlist.length + ' items saved'); }

// ── CARD BUILDERS ─────────────────────────────────────
function buildProductCard(p) {
  const badge = p.badge === 'new' ? '<span class="product-badge badge-new">New</span>'
              : p.badge === 'wholesale' ? '<span class="product-badge badge-wholesale">Wholesale</span>' : '';
  const isFav = wishlist.includes(p.id);
  const heartSvg = isFav
    ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="#C0392B" stroke="#C0392B" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>'
    : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
  const cartSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>';
  return `
    <div class="product-card" onclick="openModal(${p.id})">
      <div class="product-img-wrap">
        <img src="${p.img}" alt="${p.name}" loading="lazy">
        ${badge}
        <button class="fav-btn" onclick="event.stopPropagation();toggleFav(${p.id})" title="Add to Wishlist">${heartSvg}</button>
      </div>
      <div class="product-info">
        <p class="product-cat-label">${p.catLabel}</p>
        <h3 class="product-name">${p.name}</h3>
        <div class="product-price-row">
          <div>
            <div class="product-price">${fmt(p.price)}</div>
            ${currency !== 'USD' ? '<div class="product-price-alt">$' + Math.round(p.price/1550) + '</div>' : ''}
          </div>
          <button class="add-cart-btn" onclick="event.stopPropagation();addToCart(${p.id})" title="Add to Cart">${cartSvg}</button>
        </div>
      </div>
    </div>`;
}

function buildFabricCard(p) {
  const isFav = wishlist.includes(p.id);
  const heartSvg = isFav
    ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="#C0392B" stroke="#C0392B" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>'
    : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
  const cartSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>';
  return `
    <div class="fabric-card" onclick="openModal(${p.id})">
      <div class="fabric-img-wrap" style="position:relative;">
        <img src="${p.img}" alt="${p.name}" loading="lazy">
        <button class="fav-btn" onclick="event.stopPropagation();toggleFav(${p.id})" title="Add to Wishlist">${heartSvg}</button>
      </div>
      <div class="fabric-info">
        <h3 class="fabric-name">${p.name}</h3>
        <p class="fabric-meta">${p.moq ? p.moq.toUpperCase() + ' · ' : ''}HAND BATIK</p>
        <div class="fabric-price-row">
          <div>
            <div class="fabric-price">${fmt(p.price)}</div>
            ${currency !== 'USD' ? '<div style="font-family:\'DM Mono\',monospace;font-size:9px;color:var(--ink-muted)">$' + Math.round(p.price/1550) + '</div>' : ''}
          </div>
          <button class="add-cart-btn" onclick="event.stopPropagation();addToCart(${p.id})" title="Add to Cart">${cartSvg}</button>
        </div>
      </div>
    </div>`;
}

// ── RENDER GRID ───────────────────────────────────────
function renderGrid() {
  const products = getFilteredProducts();
  const grid = document.getElementById('shopGrid');
  const empty = document.getElementById('emptyState');
  const count = document.getElementById('productCount');
  if (products.length === 0) {
    grid.style.display = 'none'; empty.style.display = 'block';
    count.textContent = 'No products found'; return;
  }
  grid.style.display = ''; empty.style.display = 'none';
  count.textContent = 'Showing ' + products.length + ' product' + (products.length > 1 ? 's' : '');
  grid.innerHTML = products.map(p => p.cat === 'fabrics' ? buildFabricCard(p) : buildProductCard(p)).join('');
}

// ── MODAL ─────────────────────────────────────────────
function openModal(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  document.getElementById('modal-img').src = p.img;
  document.getElementById('modal-img').alt = p.name;
  document.getElementById('modal-cat').textContent = p.catLabel;
  document.getElementById('modal-title').textContent = p.name;
  document.getElementById('modal-desc').textContent = p.desc;
  document.getElementById('modal-price').textContent = fmt(p.price);
  const alts = Object.keys(RATES).filter(c => c !== currency).map(c =>
    '<span class="modal-price-alt-item">' + SYMS[c] + Math.round(p.price * RATES[c]).toLocaleString() + '</span>'
  ).join('');
  document.getElementById('modal-alts').innerHTML = alts;
  document.getElementById('modal-size-section').style.display = p.cat === 'bubus' ? 'block' : 'none';
  document.getElementById('modal-cart-btn').onclick = () => { addToCart(id); closeModal(); };
  const isFav = wishlist.includes(id);
  document.getElementById('modal-fav-btn').textContent = isFav ? '❤️ In Wishlist' : '♥ Add to Wishlist';
  document.getElementById('modal-fav-btn').onclick = () => { toggleFav(id); const f2 = wishlist.includes(id); document.getElementById('modal-fav-btn').textContent = f2 ? '❤️ In Wishlist' : '♥ Add to Wishlist'; };
  const msg = 'Hi! I\'m interested in: ' + p.name + ' (' + fmt(p.price) + '). Please confirm availability.';
  document.getElementById('modal-wa-btn').href = 'https://wa.me/2349160481729?text=' + encodeURIComponent(msg);
  document.getElementById('productModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal() { document.getElementById('productModal').classList.remove('open'); document.body.style.overflow = ''; }
document.getElementById('productModal').addEventListener('click', e => { if (e.target === document.getElementById('productModal')) closeModal(); });
function selectSize(btn) { document.querySelectorAll('.size-opt').forEach(b => b.classList.remove('active')); btn.classList.add('active'); }

// ── CART ──────────────────────────────────────────────
function addToCart(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  const ex = cart.find(i => i.id === id);
  if (ex) ex.qty++; else cart.push({ ...p, qty: 1 });
  localStorage.setItem('afroposh_cart', JSON.stringify(cart));
  updateCartDisplay();
  showToast('✓ ' + p.name + ' added to cart');
}
function removeFromCart(id) {
  cart = cart.filter(i => i.id !== id);
  localStorage.setItem('afroposh_cart', JSON.stringify(cart));
  updateCartDisplay();
}
function updateCartDisplay() {
  const count = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('cartCount').textContent = count;
  const mobCount = document.getElementById('mobCartCount');
  if (mobCount) { mobCount.textContent = count; mobCount.style.display = count > 0 ? 'flex' : 'none'; }
  const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
  document.getElementById('cartTotal').textContent = fmt(total);
  const body = document.getElementById('cartBody');
  if (cart.length === 0) {
    body.innerHTML = '<div style="text-align:center;padding:60px 24px;"><div style="font-size:48px;margin-bottom:14px;">🛍️</div><p style="font-size:15px;color:var(--ink-muted);">Your cart is empty.<br>Add something beautiful.</p></div>';
  } else {
    body.innerHTML = cart.map(i => '<div class="cart-item"><div class="cart-item-thumb"><img src="' + i.img + '" alt="' + i.name + '" loading="lazy"></div><div class="cart-item-detail"><div class="cart-item-name">' + i.name + '</div><div class="cart-item-sub">' + i.catLabel + ' · Qty: ' + i.qty + '</div><div class="cart-item-price">' + fmt(i.price * i.qty) + '</div><button class="cart-item-rm" onclick="removeFromCart(' + i.id + ')">Remove</button></div></div>').join('');
  }
}
function toggleCart() {
  document.getElementById('cartDrawer').classList.toggle('open');
  document.getElementById('cartBackdrop').classList.toggle('open');
}

// ── TOAST ─────────────────────────────────────────────
function showToast(msg) { const t = document.getElementById('toast'); t.textContent = msg; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 3000); }

// ── MOBILE MORE ──────────────────────────────────────
function toggleMobileMore() {
  const m = document.getElementById('mobileMoreMenu');
  const b = document.getElementById('moreBackdrop');
  const isOpen = m.classList.contains('open');
  if (isOpen) { m.classList.remove('open'); b.classList.remove('open'); }
  else { m.classList.add('open'); b.classList.add('open'); }
}

// ── BACK TO TOP ──────────────────────────────────────
window.addEventListener('scroll', () => {
  const btn = document.getElementById('backToTop');
  if (window.scrollY > 400) btn.classList.add('visible');
  else btn.classList.remove('visible');
}, { passive: true });

// ── COOKIE CONSENT ───────────────────────────────────
window.acceptCookies = function() { localStorage.setItem('afroposh_cookies', 'accepted'); document.getElementById('cookieBanner').classList.remove('visible'); };
window.declineCookies = function() { localStorage.setItem('afroposh_cookies', 'declined'); document.getElementById('cookieBanner').classList.remove('visible'); };

// ── Expose all onclick handlers to window ────────────
window.toggleMobileMore = toggleMobileMore;
window.toggleCart = toggleCart;
window.toggleWishlistPanel = toggleWishlistPanel;
window.setCurrency = setCurrency;
window.addToCart = addToCart;
window.removeFromCart = removeFromCart;
window.toggleFav = toggleFav;
window.showToast = showToast;
window.filterBy = filterBy;

// ── INIT ──────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const params = new URLSearchParams(window.location.search);
  const catParam = params.get('cat');
  if (catParam && ['bubus', 'fabrics', 'accessories'].includes(catParam)) {
    activeFilter = catParam;
    document.querySelectorAll('.filter-tab').forEach(t => {
      t.classList.remove('active');
      if ((catParam === 'bubus' && t.textContent.includes('Bubu')) ||
          (catParam === 'fabrics' && t.textContent.includes('Fabrics')) ||
          (catParam === 'accessories' && t.textContent.includes('Accessories'))) t.classList.add('active');
    });
  }
  renderGrid();
  updateCartDisplay();
  updateWishCount();
  checkAuth();
  if (!localStorage.getItem('afroposh_cookies')) {
    setTimeout(() => document.getElementById('cookieBanner').classList.add('visible'), 1500);
  }
});
</script>

