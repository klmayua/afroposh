---
import { PRODUCTS } from '../data/products.ts';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shop All — Afroposh Afriture</title>
  <meta name="description" content="Browse all 22 premium African fashion products. Bubu dresses, Ankara fabrics, and artisan accessories.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/src/styles/global.css">
</head>
<body>

<!-- ANNOUNCE BAR -->
<div class="announce-bar">
  🌍 Pan-African delivery · Lagos · Accra · Yaoundé · Worldwide &nbsp;|&nbsp;
  <span>Premium Batik Fabrics now in stock — Wholesale available</span>
</div>

<!-- NAV -->
<nav class="main-nav scrolled" id="mainNav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">Afroposh <span>Afriture</span></a>
    <ul class="nav-links">
      <li><a href="/shop?cat=bubus">Bubu Dresses</a></li>
      <li><a href="/shop?cat=fabrics">Fabrics</a></li>
      <li><a href="/shop?cat=accessories">Accessories</a></li>
      <li><a href="/wholesale">Wholesale</a></li>
    </ul>
    <div style="display:flex;align-items:center;gap:16px;">
      <select id="currencySelect" onchange="setCurrency(this.value)"
        style="font-family:'DM Mono',monospace;font-size:11px;border:1px solid var(--border-strong);border-radius:3px;padding:6px 10px;background:white;color:var(--ink);cursor:pointer;letter-spacing:0.05em;">
        <option value="NGN">₦ NGN</option>
        <option value="USD">$ USD</option>
        <option value="GBP">£ GBP</option>
        <option value="FCFA">FCFA</option>
        <option value="GHS">GHS</option>
      </select>
      <button onclick="toggleCart()" style="position:relative;width:40px;height:40px;border-radius:50%;background:var(--surface);border:1px solid var(--border-strong);color:var(--ink);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;">
        🛒
        <span id="cartCount" data-cart-count style="position:absolute;top:-2px;right:-2px;width:18px;height:18px;background:var(--gold);border-radius:50%;font-size:10px;font-weight:700;color:white;display:flex;align-items:center;justify-content:center;font-family:'DM Mono',monospace;">0</span>
      </button>
      <a href="/admin" style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:8px 16px;border:1.5px solid var(--ink);border-radius:3px;color:var(--ink);transition:all 0.3s;text-decoration:none;">Dashboard</a>
    </div>
  </div>
</nav>

<!-- SHOP HEADER -->
<div class="shop-header" style="background:white;padding:140px 32px 48px;text-align:center;">
  <p class="section-eyebrow" style="justify-content:center;">Our Collection</p>
  <h1 class="section-title">Shop <em>All Products</em></h1>
  <p class="section-sub" style="margin:14px auto 0;">Premium Ankara Bubu dresses, batik fabrics, and artisan accessories.</p>
  <p id="productCount" style="font-family:'DM Mono',monospace;font-size:11px;color:var(--ink-muted);margin-top:18px;letter-spacing:0.1em;">Showing 22 products</p>
</div>

<!-- SHOP BODY -->
<div class="shop-body" style="background:var(--surface);padding:0 32px 80px;">
  <div style="max-width:1400px;margin:0 auto;">
    <!-- FILTER BAR -->
    <div class="filter-bar" style="position:sticky;top:110px;z-index:50;background:var(--surface);padding:24px 0;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
      <div id="filterTabs" style="display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;">
        <button class="filter-tab active" onclick="filterBy('all')">All</button>
        <button class="filter-tab" onclick="filterBy('bubus')">Bubu Dresses</button>
        <button class="filter-tab" onclick="filterBy('fabrics')">Fabrics</button>
        <button class="filter-tab" onclick="filterBy('accessories')">Accessories</button>
      </div>
      <select id="sortSelect" onchange="sortProducts(this.value)" style="font-family:'DM Mono',monospace;font-size:11px;border:1.5px solid var(--border-strong);border-radius:3px;padding:8px 14px;background:white;color:var(--ink);cursor:pointer;">
        <option value="featured">Featured</option>
        <option value="price-asc">Price: Low → High</option>
        <option value="price-desc">Price: High → Low</option>
        <option value="newest">Newest First</option>
      </select>
    </div>

    <!-- PRODUCT GRID -->
    <div class="product-grid" id="shopGrid" style="min-height:400px;"></div>

    <!-- EMPTY STATE -->
    <div id="emptyState" style="display:none;text-align:center;padding:80px 24px;">
      <div style="font-size:48px;margin-bottom:14px;">🔍</div>
      <p style="font-size:15px;color:var(--ink-muted);">No products match this filter.<br>Try another category.</p>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div>
        <div class="footer-brand-name">Afroposh <span>Afriture</span></div>
        <p class="footer-desc">Premium Ankara Bubu dresses, batik fabrics, and artisan accessories. Celebrating African heritage through fashion.</p>
        <div class="footer-presence">
          <span class="presence-tag">Lagos</span>
          <span class="presence-tag">Accra</span>
          <span class="presence-tag">Yaoundé</span>
          <span class="presence-tag">London</span>
          <span class="presence-tag">Houston</span>
        </div>
      </div>
      <div>
        <div class="footer-col-head">Shop</div>
        <ul class="footer-links">
          <li><a href="/shop?cat=bubus">Bubu Dresses</a></li>
          <li><a href="/shop?cat=fabrics">Ankara Fabrics</a></li>
          <li><a href="/shop?cat=accessories">Accessories & Beads</a></li>
          <li><a href="/wholesale">Wholesale</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-head">Help</div>
        <ul class="footer-links">
          <li><a href="#">Sizing Guide</a></li>
          <li><a href="#">Shipping Info</a></li>
          <li><a href="#">Returns Policy</a></li>
          <li><a href="https://wa.me/2371184837" target="_blank">WhatsApp Support</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-head">Follow</div>
        <ul class="footer-links">
          <li><a href="#">Instagram @AfroposhAfritude</a></li>
          <li><a href="#">TikTok @helpforhelp</a></li>
          <li><a href="#">Facebook — Afro-posh Luxe</a></li>
        </ul>
        <div style="margin-top:22px;">
          <div class="footer-col-head">WhatsApp Direct</div>
          <a href="https://wa.me/2371184837" target="_blank" class="btn-whatsapp" style="margin-top:10px;font-size:12px;padding:10px 16px;">💬 +237 611 84837</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">© 2025 Afroposh Afriture. All rights reserved.</p>
      <div class="footer-pay-logos">
        <span class="footer-pay">FLUTTERWAVE</span>
        <span class="footer-pay">PAYSTACK</span>
        <span class="footer-pay">VISA</span>
        <span class="footer-pay">MASTERCARD</span>
      </div>
    </div>
  </div>
</footer>

<!-- PRODUCT MODAL -->
<div class="modal-wrap" id="productModal">
  <div class="modal-box">
    <div class="modal-photo">
      <button class="modal-close-btn" onclick="closeModal()">✕</button>
      <img id="modal-img" src="" alt="">
    </div>
    <div class="modal-info">
      <p class="modal-cat" id="modal-cat"></p>
      <h2 class="modal-title" id="modal-title"></h2>
      <p class="modal-desc" id="modal-desc"></p>
      <div class="modal-price-block">
        <div class="modal-price-main" id="modal-price"></div>
        <div class="modal-price-alts" id="modal-alts"></div>
      </div>
      <div id="modal-size-section">
        <p class="size-label">Select Size</p>
        <div class="sizes">
          <button class="size-opt active" onclick="selectSize(this)">Free Size</button>
          <button class="size-opt" onclick="selectSize(this)">S/M</button>
          <button class="size-opt" onclick="selectSize(this)">L/XL</button>
          <button class="size-opt" onclick="selectSize(this)">XXL+</button>
        </div>
      </div>
      <div class="modal-btns">
        <button class="btn-dark" id="modal-cart-btn" style="justify-content:center;padding:16px;">🛒 Add to Cart</button>
        <a class="btn-whatsapp" id="modal-wa-btn" href="#" target="_blank" style="justify-content:center;">💬 Order via WhatsApp</a>
      </div>
    </div>
  </div>
</div>

<!-- CART DRAWER -->
<div class="cart-backdrop" id="cartBackdrop" onclick="toggleCart()"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-head">
    <h2 class="cart-head-title">Your Cart</h2>
    <button class="cart-x" onclick="toggleCart()">✕</button>
  </div>
  <div class="cart-body" id="cartBody">
    <div style="text-align:center;padding:60px 24px;">
      <div style="font-size:48px;margin-bottom:14px;">🛍️</div>
      <p style="font-size:15px;color:var(--ink-muted);">Your cart is empty.<br>Add something beautiful.</p>
    </div>
  </div>
  <div class="cart-foot">
    <div class="cart-total-row">
      <span class="cart-total-lbl">Total</span>
      <span class="cart-total-val" id="cartTotal">₦0</span>
    </div>
    <button class="btn-checkout" onclick="window.location.href='/checkout'">🔒 Proceed to Checkout</button>
    <div class="pay-logos">
      <span class="pay-logo">FLUTTERWAVE</span>
      <span class="pay-logo">PAYSTACK</span>
      <span class="pay-logo">VISA</span>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<style>
  .filter-tab {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 9px 20px;
    border-radius: 999px;
    border: 1.5px solid var(--border-strong);
    background: white;
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .filter-tab:hover {
    border-color: var(--ink);
    color: var(--ink);
  }
  .filter-tab.active {
    background: var(--ink);
    border-color: var(--ink);
    color: white;
  }
</style>

<script>
// ── DATA ──────────────────────────────────────────────
const RATES = { NGN: 1, USD: 1/1550, GBP: 1/1950, FCFA: 2.6, GHS: 1000/10300 };
const SYMS  = { NGN: '₦', USD: '$', GBP: '£', FCFA: 'FCFA ', GHS: 'GHS ' };
let currency = 'NGN';
let cart = JSON.parse(localStorage.getItem('afroposh_cart') || '[]');

const PRODUCTS = [
  { id:1,  name:'Tribal Geometric Maxi Bubu',      cat:'bubus',       catLabel:'Bubu Dress',    img:'/images/dresses/tribal-geometric-maxi.jpg',  price:35000, badge:'new',       desc:'Bold geometric patterns in hot pink, black, and cobalt blue. Full-length maxi with wide sleeves and deep V-neck.' },
  { id:2,  name:'Red Teal Tribal Fringe Maxi',     cat:'bubus',       catLabel:'Bubu Dress',    img:'/images/dresses/red-teal-fringe-maxi.jpg',   price:38000, badge:'new',       desc:'Striking red and teal zigzag pattern with artisan tassel fringe at the chest. Side slit for movement.' },
  { id:3,  name:'Royal Blue & Mustard Grid Maxi',  cat:'bubus',       catLabel:'Bubu Dress',    img:'/images/dresses/royal-blue-mustard-grid.jpg', price:32000, badge:null,       desc:'Clean colour-block in cobalt blue grid print with solid mustard bodice. Deep pockets.' },
  { id:4,  name:'Olive Gold Stripe Maxi',          cat:'bubus',       catLabel:'Bubu Dress',    img:'/images/dresses/olive-gold-stripe-maxi.jpg', price:36000, badge:null,        desc:'Sophisticated earth-tone vertical stripes in olive, gold, and charcoal.' },
  { id:5,  name:'Mudcloth Bogolan Bubu',           cat:'bubus',       catLabel:'Bubu Dress',    img:'/images/dresses/mudcloth-brown-bubu.jpg',     price:30000, badge:null,       desc:'Inspired by West African bogolan tradition. Rich brown base with white symbol motifs.' },
  { id:6,  name:'Forest Green Short Bubu',         cat:'bubus',       catLabel:'Bubu Dress',    img:'/images/dresses/forest-green-short-bubu.jpg', price:27000, badge:'new',      desc:'Knee-length in deep forest green with woven tribal stripe detail.' },
  { id:7,  name:'Mustard Mixed Print Maxi',        cat:'bubus',       catLabel:'Bubu Dress',    img:'/images/dresses/mustard-mixed-print-maxi.jpg',price:34000, badge:null,       desc:'Solid mustard bodice transitions into complex mixed African print. Deep pockets.' },
  { id:8,  name:'Blue Mustard Grid Maxi',          cat:'bubus',       catLabel:'Bubu Dress',    img:'/images/dresses/blue-mustard-grid-2.jpg',     price:32000, badge:null,       desc:'The beloved Royal Blue & Mustard grid in a second colourway.' },
  { id:9,  name:'Ocean Wave Batik',                cat:'fabrics',     catLabel:'Ankara Fabric', img:'/images/fabrics/wave-batik.jpg',              price:25000, badge:'wholesale', desc:'Teal, red, and deep blue wave pattern. 6-yard bale.', moq:'6 yards' },
  { id:10, name:'Adinkra Symbol Batik',            cat:'fabrics',     catLabel:'Ankara Fabric', img:'/images/fabrics/adinkra-symbol-batik.jpg',    price:25000, badge:'wholesale', desc:'Rich purple and terracotta with Adinkra symbols. 6-yard bale.', moq:'6 yards' },
  { id:11, name:'Spiral Adinkra Batik',            cat:'fabrics',     catLabel:'Ankara Fabric', img:'/images/fabrics/spiral-adinkra-batik.jpg',    price:25000, badge:'wholesale', desc:'Vibrant orange-gold and turquoise with spiral Adinkra motifs. 6-yard bale.', moq:'6 yards' },
  { id:12, name:'Galaxy Night Batik',              cat:'fabrics',     catLabel:'Ankara Fabric', img:'/images/fabrics/galaxy-batik.jpg',            price:25000, badge:'wholesale', desc:'Deep blue-purple with cosmic speckled effect. 6-yard bale.', moq:'6 yards' },
  { id:13, name:'Mandala Fire Batik',              cat:'fabrics',     catLabel:'Ankara Fabric', img:'/images/fabrics/mandala-fire-batik.jpg',      price:27000, badge:'wholesale', desc:'Hot pink, orange, and red floral mandala on black. 6-yard bale.', moq:'6 yards' },
  { id:14, name:'Emerald Diamond Batik',           cat:'fabrics',     catLabel:'Ankara Fabric', img:'/images/fabrics/emerald-diamond-batik.jpg',   price:24000, badge:'wholesale', desc:'Forest green with geometric diamond overlay. 6-yard bale.', moq:'6 yards' },
  { id:15, name:'Harvest Splatter Batik',          cat:'fabrics',     catLabel:'Ankara Fabric', img:'/images/fabrics/harvest-splatter-batik.jpg',  price:23000, badge:'wholesale', desc:'Yellow, olive, orange, and black splatter technique. 6-yard bale.', moq:'6 yards' },
  { id:16, name:'Teal Rust Crackle Batik',         cat:'fabrics',     catLabel:'Ankara Fabric', img:'/images/fabrics/teal-rust-crackle-batik.jpg', price:24000, badge:'wholesale', desc:'Teal with rust crackle texture. 6-yard bale.', moq:'6 yards' },
  { id:17, name:'Ankara Tote Bag',                 cat:'accessories', catLabel:'Bag',           img:'/images/accessories/ankara-tote-hat.jpg',     price:15000, badge:'new',       desc:'Jute and Ankara fabric tote with rope handles. 3 prints available.' },
  { id:18, name:'Zulu Beaded Collar Necklace',     cat:'accessories', catLabel:'Jewellery',     img:'/images/accessories/zulu-collar-necklace.jpg',price:28000, badge:'new',       desc:'Architectural Zulu-inspired beaded collar. Blue, green, and black geometric pattern.' },
  { id:19, name:'Beaded Leather Sandals',          cat:'accessories', catLabel:'Footwear',      img:'/images/accessories/beaded-sandals.jpg',       price:18000, badge:null,       desc:'Handcrafted dark leather sandals with intricate beaded floral embellishments.' },
  { id:20, name:'Zulu Fringe Necklace',            cat:'accessories', catLabel:'Jewellery',     img:'/images/accessories/zulu-fringe-necklaces.jpg',price:22000, badge:null,       desc:'Classic Zulu beaded necklace with geometric diamond chest plate.' },
  { id:21, name:'Beaded Watch Cuff',               cat:'accessories', catLabel:'Jewellery',     img:'/images/accessories/beaded-watch-cuff.jpg',    price:20000, badge:'new',       desc:'Multicolour seed bead wide cuff with integrated watch face.' },
  { id:22, name:'Full Beaded Set + Clutch',        cat:'accessories', catLabel:'Jewellery Set', img:'/images/accessories/beaded-jewellery-set.jpg', price:55000, badge:'new',       desc:'Complete set: choker, long necklace, cuff bracelet, and leather clutch.' },
];

let activeFilter = 'all';
let activeSort = 'featured';

// ── CURRENCY ──────────────────────────────────────────
function fmt(ngn, cur = currency) {
  const v = ngn * RATES[cur];
  return SYMS[cur] + Math.round(v).toLocaleString();
}

function setCurrency(c) {
  currency = c;
  renderGrid();
  updateCartDisplay();
}

// ── FILTER & SORT ─────────────────────────────────────
function filterBy(cat) {
  activeFilter = cat;
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  renderGrid();
}

function sortProducts(val) {
  activeSort = val;
  renderGrid();
}

function getFilteredProducts() {
  let filtered = activeFilter === 'all' ? [...PRODUCTS] : PRODUCTS.filter(p => p.cat === activeFilter);
  switch(activeSort) {
    case 'price-asc': filtered.sort((a,b) => a.price - b.price); break;
    case 'price-desc': filtered.sort((a,b) => b.price - a.price); break;
    case 'newest': filtered.sort((a,b) => b.id - a.id); break;
    default: break;
  }
  return filtered;
}

// ── CARD BUILDERS ─────────────────────────────────────
function buildProductCard(p) {
  const badge = p.badge === 'new' ? '<span class="product-badge badge-new">New</span>'
              : p.badge === 'wholesale' ? '<span class="product-badge badge-wholesale">Wholesale</span>' : '';
  return `
    <div class="product-card" onclick="openModal(${p.id})">
      <div class="product-img-wrap">
        <img src="${p.img}" alt="${p.name}" loading="lazy">
        ${badge}
        <span class="product-wishlist">🤍</span>
      </div>
      <div class="product-info">
        <p class="product-cat-label">${p.catLabel}</p>
        <h3 class="product-name">${p.name}</h3>
        <div class="product-price-row">
          <div>
            <div class="product-price">${fmt(p.price)}</div>
            ${currency !== 'USD' ? `<div class="product-price-alt">≈ $${Math.round(p.price/1550)}</div>` : ''}
          </div>
          <button class="add-cart-btn" onclick="event.stopPropagation();addToCart(${p.id})">+</button>
        </div>
      </div>
    </div>`;
}

function buildFabricCard(p) {
  return `
    <div class="fabric-card" onclick="openModal(${p.id})">
      <div class="fabric-img-wrap">
        <img src="${p.img}" alt="${p.name}" loading="lazy">
      </div>
      <div class="fabric-info">
        <h3 class="fabric-name">${p.name}</h3>
        <p class="fabric-meta">${p.moq ? p.moq.toUpperCase() + ' · ' : ''}HAND BATIK</p>
        <div class="fabric-price-row">
          <div>
            <div class="fabric-price">${fmt(p.price)}</div>
            ${currency !== 'USD' ? `<div style="font-family:'DM Mono',monospace;font-size:9px;color:var(--ink-muted)">≈ $${Math.round(p.price/1550)}</div>` : ''}
          </div>
          <span class="wholesale-tag">Wholesale</span>
        </div>
      </div>
    </div>`;
}

// ── RENDER GRID ───────────────────────────────────────
function renderGrid() {
  const products = getFilteredProducts();
  const grid = document.getElementById('shopGrid');
  const empty = document.getElementById('emptyState');
  const count = document.getElementById('productCount');

  if (products.length === 0) {
    grid.style.display = 'none';
    empty.style.display = 'block';
    count.textContent = 'No products found';
    return;
  }

  grid.style.display = '';
  empty.style.display = 'none';
  count.textContent = `Showing ${products.length} product${products.length > 1 ? 's' : ''}`;

  grid.innerHTML = products.map(p => p.cat === 'fabrics' ? buildFabricCard(p) : buildProductCard(p)).join('');
}

// ── MODAL ─────────────────────────────────────────────
function openModal(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  document.getElementById('modal-img').src = p.img;
  document.getElementById('modal-img').alt = p.name;
  document.getElementById('modal-cat').textContent = p.catLabel;
  document.getElementById('modal-title').textContent = p.name;
  document.getElementById('modal-desc').textContent = p.desc;
  document.getElementById('modal-price').textContent = fmt(p.price);
  const alts = Object.keys(RATES).filter(c => c !== currency).map(c =>
    `<span class="modal-price-alt-item">${SYMS[c]}${Math.round(p.price * RATES[c]).toLocaleString()}</span>`
  ).join('');
  document.getElementById('modal-alts').innerHTML = alts;
  document.getElementById('modal-size-section').style.display = p.cat === 'bubus' ? 'block' : 'none';
  document.getElementById('modal-cart-btn').onclick = () => { addToCart(id); closeModal(); };
  const msg = `Hi! I'm interested in: ${p.name} (${fmt(p.price)}). Please confirm availability.`;
  document.getElementById('modal-wa-btn').href = `https://wa.me/2371184837?text=${encodeURIComponent(msg)}`;
  document.getElementById('productModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('productModal').classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('productModal').addEventListener('click', e => {
  if (e.target === document.getElementById('productModal')) closeModal();
});

function selectSize(btn) {
  document.querySelectorAll('.size-opt').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ── CART ──────────────────────────────────────────────
function addToCart(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  const ex = cart.find(i => i.id === id);
  if (ex) ex.qty++;
  else cart.push({ ...p, qty: 1 });
  localStorage.setItem('afroposh_cart', JSON.stringify(cart));
  updateCartDisplay();
  showToast(`✓ ${p.name} added to cart`);
}

function removeFromCart(id) {
  cart = cart.filter(i => i.id !== id);
  localStorage.setItem('afroposh_cart', JSON.stringify(cart));
  updateCartDisplay();
}

function updateCartDisplay() {
  const count = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('cartCount').textContent = count;
  const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
  document.getElementById('cartTotal').textContent = fmt(total);

  const body = document.getElementById('cartBody');
  if (cart.length === 0) {
    body.innerHTML = `<div style="text-align:center;padding:60px 24px;"><div style="font-size:48px;margin-bottom:14px;">🛍️</div><p style="font-size:15px;color:var(--ink-muted);">Your cart is empty.<br>Add something beautiful.</p></div>`;
  } else {
    body.innerHTML = cart.map(i => `
      <div class="cart-item">
        <div class="cart-item-thumb"><img src="${i.img}" alt="${i.name}" loading="lazy"></div>
        <div class="cart-item-detail">
          <div class="cart-item-name">${i.name}</div>
          <div class="cart-item-sub">${i.catLabel} · Qty: ${i.qty}</div>
          <div class="cart-item-price">${fmt(i.price * i.qty)}</div>
          <button class="cart-item-rm" onclick="removeFromCart(${i.id})">Remove</button>
        </div>
      </div>`).join('');
  }
}

function toggleCart() {
  document.getElementById('cartDrawer').classList.toggle('open');
  document.getElementById('cartBackdrop').classList.toggle('open');
}

// ── TOAST ─────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ── INIT ──────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  // Read URL param for active filter
  const params = new URLSearchParams(window.location.search);
  const catParam = params.get('cat');
  if (catParam && ['bubus', 'fabrics', 'accessories'].includes(catParam)) {
    activeFilter = catParam;
    document.querySelectorAll('.filter-tab').forEach(t => {
      t.classList.remove('active');
      if ((catParam === 'bubus' && t.textContent.includes('Bubu')) ||
          (catParam === 'fabrics' && t.textContent.includes('Fabrics')) ||
          (catParam === 'accessories' && t.textContent.includes('Accessories'))) {
        t.classList.add('active');
      }
    });
  }
  renderGrid();
  updateCartDisplay();
});
</script>

</body>
</html>
