---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Afroposh Afriture</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

<!-- PREMIUM TICKER -->
<div class="premium-ticker" id="premiumTicker">
  <div class="ticker-track">
    <span class="ticker-item ticker-gold">✦ Premium Batik Fabrics Now In Stock</span>
    <span class="ticker-item ticker-green">🚚 Free Delivery on Orders Over ₦100,000</span>
    <span class="ticker-item ticker-blue">📦 Wholesale Available — Minimum 6 Yards</span>
    <span class="ticker-item ticker-purple">🔥 New Bubu Dress Collection Just Dropped</span>
    <span class="ticker-item ticker-gold">✦ Premium Batik Fabrics Now In Stock</span>
    <span class="ticker-item ticker-green">🚚 Free Delivery on Orders Over ₦100,000</span>
    <span class="ticker-item ticker-blue">📦 Wholesale Available — Minimum 6 Yards</span>
    <span class="ticker-item ticker-purple">🔥 New Bubu Dress Collection Just Dropped</span>
  </div>
</div>

<!-- NAV -->
<nav class="main-nav scrolled" id="mainNav">
  <div class="nav-inner">
    <ul class="nav-links">
      <li><a href="/shop?cat=bubus">Bubu Dresses</a></li>
      <li><a href="/shop?cat=fabrics">Fabrics</a></li>
      <li><a href="/shop?cat=accessories">Accessories</a></li>
      <li><a href="/wholesale">Wholesale</a></li>
    </ul>
    <a href="/" class="nav-logo">Afroposh <span>Afriture</span></a>
    <div class="nav-ctas">
      <a href="/shop" style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:8px 16px;border:1.5px solid var(--ink);border-radius:3px;color:var(--ink);transition:all 0.3s;text-decoration:none;">← Shop</a>
    </div>
  </div>
</nav>

<!-- LOGIN PAGE CONTENT -->
<main style="min-height:100vh;padding-top:120px;display:grid;grid-template-columns:1fr 1fr;background:var(--surface);">
  <!-- LEFT: Hero Visual — rotating product images, zoomed out to show full outfits -->
  <div style="position:relative;overflow:hidden;background:#0a0a0a;" id="loginHeroPanel">
    <!-- Slides -->
    <div class="lp-slide lp-active" style="position:absolute;inset:0;transition:opacity 1.4s ease;">
      <img src="/images/dresses/afroposh_bubu4.jpg"  alt="" style="width:100%;height:100%;object-fit:cover;object-position:center 15%;transform:scale(1.0);">
    </div>
    <div class="lp-slide" style="position:absolute;inset:0;opacity:0;transition:opacity 1.4s ease;">
      <img src="/images/dresses/afroposh_bubu8.jpg"  alt="" style="width:100%;height:100%;object-fit:cover;object-position:center 10%;transform:scale(1.0);">
    </div>
    <div class="lp-slide" style="position:absolute;inset:0;opacity:0;transition:opacity 1.4s ease;">
      <img src="/images/dresses/afroposh_bubu3.jpg"  alt="" style="width:100%;height:100%;object-fit:cover;object-position:center 8%;transform:scale(1.0);">
    </div>
    <div class="lp-slide" style="position:absolute;inset:0;opacity:0;transition:opacity 1.4s ease;">
      <img src="/images/dresses/afroposh_bubu2.jpg"  alt="" style="width:100%;height:100%;object-fit:cover;object-position:center 5%;transform:scale(1.0);">
    </div>
    <!-- Dark gradient overlay -->
    <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.35) 50%, rgba(0,0,0,0.2) 100%);z-index:2;"></div>
    <!-- Content over image -->
    <div style="position:absolute;inset:0;z-index:3;display:flex;flex-direction:column;justify-content:flex-end;padding:40px;">
      <p style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold-light);margin-bottom:12px;">Afroposh Afriture</p>
      <h2 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(30px,3.5vw,44px);color:white;font-weight:500;line-height:1.1;margin-bottom:14px;">Your African<br><em style="color:var(--gold-light);">Fashion Journey</em><br>Starts Here</h2>
      <p style="color:rgba(255,255,255,0.55);font-size:13px;max-width:320px;line-height:1.6;">Premium Bubu dresses, Ankara fabrics, and artisan accessories delivered worldwide.</p>
      <div style="display:flex;gap:6px;margin-top:20px;">
        <span style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.1em;color:rgba(255,255,255,0.45);padding:4px 10px;border:1px solid rgba(255,255,255,0.15);border-radius:3px;">Lagos</span>
        <span style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.1em;color:rgba(255,255,255,0.45);padding:4px 10px;border:1px solid rgba(255,255,255,0.15);border-radius:3px;">Accra</span>
        <span style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.1em;color:rgba(255,255,255,0.45);padding:4px 10px;border:1px solid rgba(255,255,255,0.15);border-radius:3px;">Yaoundé</span>
      </div>
    </div>
  </div>

  <!-- RIGHT: Form -->
  <div style="display:flex;align-items:center;justify-content:center;padding:40px 32px;">
    <div style="width:100%;max-width:420px;">

      <!-- LOGIN CARD -->
      <div id="loginCard">
        <div style="margin-bottom:32px;">
          <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:32px;font-weight:500;margin-bottom:6px;">Welcome Back</h1>
          <p style="font-size:13px;color:var(--ink-muted);">Sign in to your Afroposh account</p>
        </div>

        <!-- ROLE TOGGLE -->
        <div style="display:flex;border:1.5px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:24px;">
          <button id="tabCustomer" onclick="setRole('customer')" style="flex:1;padding:10px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;border:none;cursor:pointer;transition:all 0.2s;background:var(--ink);color:white;">Customer</button>
          <button id="tabAdmin" onclick="setRole('admin')" style="flex:1;padding:10px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;border:none;cursor:pointer;transition:all 0.2s;background:white;color:var(--ink-muted);">Admin</button>
        </div>

        <form id="loginForm" onsubmit="handleLogin(event)">
          <div style="margin-bottom:18px;">
            <label class="form-lbl">Email Address</label>
            <input class="form-ctrl" type="email" id="loginEmail" required placeholder="you@email.com">
          </div>
          <div style="margin-bottom:24px;">
            <label class="form-lbl">Password</label>
            <input class="form-ctrl" type="password" id="loginPassword" required placeholder="••••••••">
          </div>
          <div id="loginError" style="display:none;background:#FEF0EF;border:1px solid #F5C6CB;border-radius:4px;padding:10px 14px;margin-bottom:16px;font-size:12px;color:#C0392B;"></div>
          <button type="submit" class="btn-primary" style="width:100%;justify-content:center;padding:16px;">Sign In →</button>
        </form>

        <div style="text-align:center;margin-top:20px;">
          <p style="font-size:11px;color:var(--ink-muted);">Don't have an account? <a href="#" onclick="showRegister()" style="color:var(--gold);font-weight:600;text-decoration:none;">Create Account</a></p>
        </div>

        <!-- QUICK LOGIN CARDS (simulate click) -->
        <div style="margin-top:28px;padding-top:20px;border-top:1px solid var(--border);">
          <p style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.1em;color:var(--ink-muted);text-transform:uppercase;margin-bottom:12px;">⚡ Quick Demo Login — Click to sign in instantly</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <button onclick="fillDemo('customer')" style="padding:14px 12px;border:1.5px solid var(--gold);border-radius:8px;background:linear-gradient(135deg,#FFF9E6,#FFFDF5);cursor:pointer;text-align:left;transition:all 0.2s;box-shadow:0 2px 8px rgba(201,146,42,0.1);">
              <div style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:600;color:var(--ink);margin-bottom:4px;">🛍️ Shop as Customer</div>
              <div style="font-family:'DM Mono',monospace;font-size:9px;color:var(--ink-muted);">customer@afroposh.com</div>
            </button>
            <button onclick="fillDemo('admin')" style="padding:14px 12px;border:1.5px solid var(--ink);border-radius:8px;background:linear-gradient(135deg,#F0F0F0,#FAFAFA);cursor:pointer;text-align:left;transition:all 0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
              <div style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:600;color:var(--ink);margin-bottom:4px;">📊 Admin Dashboard</div>
              <div style="font-family:'DM Mono',monospace;font-size:9px;color:var(--ink-muted);">admin@afroposh.com</div>
            </button>
          </div>
        </div>
      </div>

      <!-- REGISTER CARD (hidden) -->
      <div id="registerCard" style="display:none;">
        <div style="margin-bottom:32px;">
          <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:32px;font-weight:500;margin-bottom:6px;">Create Account</h1>
          <p style="font-size:13px;color:var(--ink-muted);">Join the Afroposh family</p>
        </div>
        <form id="registerForm" onsubmit="handleRegister(event)">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;">
            <div>
              <label class="form-lbl">First Name</label>
              <input class="form-ctrl" type="text" id="regFirst" required placeholder="First name">
            </div>
            <div>
              <label class="form-lbl">Last Name</label>
              <input class="form-ctrl" type="text" id="regLast" required placeholder="Last name">
            </div>
          </div>
          <div style="margin-bottom:18px;">
            <label class="form-lbl">Email Address</label>
            <input class="form-ctrl" type="email" id="regEmail" required placeholder="you@email.com">
          </div>
          <div style="margin-bottom:18px;">
            <label class="form-lbl">WhatsApp Number</label>
            <input class="form-ctrl" type="tel" id="regPhone" required placeholder="+234 8XX XXX XXXX">
          </div>
          <div style="margin-bottom:18px;">
            <label class="form-lbl">Country</label>
            <select class="form-ctrl" id="regCountry" required>
              <option value="">Select country</option>
              <option value="Nigeria">Nigeria</option>
              <option value="Ghana">Ghana</option>
              <option value="Cameroon">Cameroon</option>
              <option value="UK">United Kingdom</option>
              <option value="US">United States</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div style="margin-bottom:24px;">
            <label class="form-lbl">Password</label>
            <input class="form-ctrl" type="password" id="regPassword" required placeholder="Min 6 characters" minlength="6">
          </div>
          <div id="regError" style="display:none;background:#FEF0EF;border:1px solid #F5C6CB;border-radius:4px;padding:10px 14px;margin-bottom:16px;font-size:12px;color:#C0392B;"></div>
          <button type="submit" class="btn-primary" style="width:100%;justify-content:center;padding:16px;">Create Account →</button>
        </form>
        <div style="text-align:center;margin-top:20px;">
          <p style="font-size:11px;color:var(--ink-muted);">Already have an account? <a href="#" onclick="showLogin()" style="color:var(--gold);font-weight:600;text-decoration:none;">Sign In</a></p>
        </div>
      </div>

    </div>
  </div>
</main>

<style>
  @media (max-width: 768px) {
    main { grid-template-columns: 1fr !important; }
    main > div:first-child { display: none !important; }
  }
</style>

<div class="toast" id="toast"></div>

<script>
// ── DEMO USER DB (localStorage-backed) ────────────────
const DEMO_USERS = [
  { email:'customer@afroposh.com', password:'demo2026', firstName:'Amara', lastName:'Okafor', role:'customer', country:'Nigeria', phone:'+234 801 234 5678' },
  { email:'admin@afroposh.com', password:'admin2026', firstName:'Joyce', lastName:'Admin', role:'admin', country:'Cameroon', phone:'+237 611 84837' },
];

let selectedRole = 'customer';

function setRole(role) {
  selectedRole = role;
  document.getElementById('tabCustomer').style.background = role === 'customer' ? 'var(--ink)' : 'white';
  document.getElementById('tabCustomer').style.color = role === 'customer' ? 'white' : 'var(--ink-muted)';
  document.getElementById('tabAdmin').style.background = role === 'admin' ? 'var(--ink)' : 'white';
  document.getElementById('tabAdmin').style.color = role === 'admin' ? 'white' : 'var(--ink-muted)';
}

function fillDemo(type) {
  if (type === 'customer') {
    document.getElementById('loginEmail').value = 'customer@afroposh.com';
    document.getElementById('loginPassword').value = 'demo2026';
    setRole('customer');
  } else {
    document.getElementById('loginEmail').value = 'admin@afroposh.com';
    document.getElementById('loginPassword').value = 'admin2026';
    setRole('admin');
  }
  const errEl = document.getElementById('loginError');
  if (errEl) errEl.style.display = 'none';

  // Flash the button, then auto-submit — no second click needed
  const btn = document.querySelector('#loginForm button[type="submit"]');
  if (btn) {
    btn.textContent = 'Signing in…';
    btn.style.background = 'var(--gold)';
    btn.disabled = true;
  }
  setTimeout(() => {
    document.getElementById('loginForm').dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
  }, 500);
}

function handleLogin(e) {
  e.preventDefault();
  const btn = document.querySelector('#loginForm button[type="submit"]');
  const email = document.getElementById('loginEmail').value.trim().toLowerCase();
  const password = document.getElementById('loginPassword').value;
  const errEl = document.getElementById('loginError');
  errEl.style.display = 'none';

  // Check demo users
  let user = DEMO_USERS.find(u => u.email === email && u.password === password);

  // Check registered users in localStorage
  if (!user) {
    const registered = JSON.parse(localStorage.getItem('afroposh_registered') || '[]');
    const reg = registered.find(u => u.email === email && u.password === password);
    if (reg) user = reg;
  }

  if (!user) {
    if (btn) { btn.textContent = 'Sign In →'; btn.style.background = ''; btn.disabled = false; }
    errEl.style.display = 'block';
    errEl.textContent = 'Invalid email or password. Try the demo credentials below.';
    return;
  }

  // Role check: admin tab requires admin account
  if (selectedRole === 'admin' && user.role !== 'admin') {
    if (btn) { btn.textContent = 'Sign In →'; btn.style.background = ''; btn.disabled = false; }
    errEl.style.display = 'block';
    errEl.textContent = 'This account does not have admin privileges.';
    return;
  }

  // Login success — always redirect based on the user's actual role
  const session = { ...user, password: undefined, loggedInAt: new Date().toISOString() };
  delete session.password;
  localStorage.setItem('afroposh_user', JSON.stringify(session));

  showToast('✓ Welcome back, ' + user.firstName + '!');
  setTimeout(() => {
    window.location.href = user.role === 'admin' ? '/admin' : '/shop';
  }, 800);
}

function handleRegister(e) {
  e.preventDefault();
  const email = document.getElementById('regEmail').value.trim().toLowerCase();
  const password = document.getElementById('regPassword').value;
  const firstName = document.getElementById('regFirst').value.trim();
  const lastName = document.getElementById('regLast').value.trim();
  const phone = document.getElementById('regPhone').value.trim();
  const country = document.getElementById('regCountry').value;
  const errEl = document.getElementById('regError');

  // Check if email already exists
  const existing = DEMO_USERS.find(u => u.email === email);
  const registered = JSON.parse(localStorage.getItem('afroposh_registered') || '[]');
  const existingReg = registered.find(u => u.email === email);

  if (existing || existingReg) {
    errEl.style.display = 'block';
    errEl.textContent = 'An account with this email already exists.';
    return;
  }

  // Register
  const newUser = { email, password, firstName, lastName, role: 'customer', country, phone };
  registered.push(newUser);
  localStorage.setItem('afroposh_registered', JSON.stringify(registered));

  // Auto-login
  const session = { ...newUser, password: undefined, loggedInAt: new Date().toISOString() };
  delete session.password;
  localStorage.setItem('afroposh_user', JSON.stringify(session));

  showToast('✓ Account created! Welcome, ' + firstName + '!');
  setTimeout(() => { window.location.href = '/shop'; }, 800);
}

function showRegister() {
  document.getElementById('loginCard').style.display = 'none';
  document.getElementById('registerCard').style.display = 'block';
}
function showLogin() {
  document.getElementById('registerCard').style.display = 'none';
  document.getElementById('loginCard').style.display = 'block';
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ── Expose handlers to global scope (Astro bundles scripts as modules) ──
window.fillDemo      = fillDemo;
window.setRole       = setRole;
window.handleLogin   = handleLogin;
window.handleRegister = handleRegister;
window.showRegister  = showRegister;
window.showLogin     = showLogin;
window.showToast     = showToast;

// Redirect if already logged in
document.addEventListener('DOMContentLoaded', () => {
  const user = JSON.parse(localStorage.getItem('afroposh_user') || 'null');
  if (user) {
    window.location.href = user.role === 'admin' ? '/admin' : '/shop';
  }

  // Login page hero panel slideshow
  const lpSlides = document.querySelectorAll('.lp-slide');
  if (lpSlides.length) {
    let lpCurrent = 0;
    setInterval(() => {
      lpSlides[lpCurrent].style.opacity = '0';
      lpSlides[lpCurrent].classList.remove('lp-active');
      lpCurrent = (lpCurrent + 1) % lpSlides.length;
      lpSlides[lpCurrent].style.opacity = '1';
      lpSlides[lpCurrent].classList.add('lp-active');
    }, 5000);
  }
});
</script>

<style>
  /* Login page left panel fills full height */
  #loginHeroPanel { min-height: calc(100vh - 120px); }
  @media (max-width: 768px) {
    main { grid-template-columns: 1fr !important; }
    #loginHeroPanel { display: none !important; }
    /* Ensure bottom of form clears the mobile bottom nav */
    main { padding-bottom: calc(40px + 72px) !important; }
  }
</style>

</body>
</html>
