<script>
const RATES = { NGN: 1, USD: 1/1550, GBP: 1/1950, FCFA: 2.6, GHS: 1000/10300 };
const SYMS  = { NGN: '₦', USD: '$', GBP: '£', FCFA: 'FCFA ', GHS: 'GHS ' };
let currency = 'NGN';
let cart = JSON.parse(localStorage.getItem('afroposh_cart') || '[]');

function fmt(ngn, cur = currency) {
  const v = ngn * RATES[cur];
  return SYMS[cur] + Math.round(v).toLocaleString();
}
function setCurrency(c) { currency = c; updateCartDisplay(); }

function handleWholesaleSubmit(e) {
  e.preventDefault();
  showToast('✓ Inquiry submitted! We will contact you within 24 hours.');
  e.target.reset();
}

function updateCartDisplay() {
  const count = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('cartCount').textContent = count;
  const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
  document.getElementById('cartTotal').textContent = fmt(total);
}

function toggleCart() {
  document.getElementById('cartDrawer').classList.toggle('open');
  document.getElementById('cartBackdrop').classList.toggle('open');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

function checkAuth() {
  const user = JSON.parse(localStorage.getItem('afroposh_user') || 'null');
  const btn = document.getElementById('navAuthBtn');
  if (user && btn) {
    btn.textContent = user.role === 'admin' ? '📊 Dashboard' : '👤 ' + user.firstName;
    btn.href = user.role === 'admin' ? '/admin' : '#';
    if (user.role !== 'admin') btn.onclick = function(e) { e.preventDefault(); if(confirm('Log out?')) { localStorage.removeItem('afroposh_user'); location.reload(); } };
  }
}
// ── MOBILE MORE ──────────────────────────────────────
function toggleMobileMore() {
  const m = document.getElementById('mobileMoreMenu');
  const b = document.getElementById('moreBackdrop');
  const isOpen = m.classList.contains('open');
  if (isOpen) { m.classList.remove('open'); b.classList.remove('open'); }
  else { m.classList.add('open'); b.classList.add('open'); }
}

// ── BACK TO TOP ──────────────────────────────────────
window.addEventListener('scroll', () => {
  const btn = document.getElementById('backToTop');
  if (window.scrollY > 400) btn.classList.add('visible');
  else btn.classList.remove('visible');
}, { passive: true });

// ── COOKIE CONSENT ───────────────────────────────────
window.acceptCookies = function() { localStorage.setItem('afroposh_cookies', 'accepted'); document.getElementById('cookieBanner').classList.remove('visible'); };
window.declineCookies = function() { localStorage.setItem('afroposh_cookies', 'declined'); document.getElementById('cookieBanner').classList.remove('visible'); };

// ── Expose all onclick handlers to window ────────────
window.toggleMobileMore = toggleMobileMore;
window.toggleCart = toggleCart;
window.setCurrency = setCurrency;
window.updateCartDisplay = updateCartDisplay;
window.showToast = showToast;

document.addEventListener('DOMContentLoaded', () => {
  updateCartDisplay();
  checkAuth();
  if (!localStorage.getItem('afroposh_cookies')) {
    setTimeout(() => document.getElementById('cookieBanner').classList.add('visible'), 1500);
  }
});
</script>

</body>
</html>
